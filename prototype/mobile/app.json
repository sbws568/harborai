{
  "expo": {
    "name": "HarborAI",
    "slug": "harbor-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0EA5E9",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harborai.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0EA5E9"
      },
      "package": "com.harborai.app"
    },
    "plugins": ["expo-haptics"]
  }
}
