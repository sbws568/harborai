# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Mock mode — set to false for real integrations
MOCK_INTEGRATIONS=true

# Redis (for session state)
REDIS_URL=redis://localhost:6379/0

# Experian India API
EXPERIAN_API_URL=https://api.experian.in/credit/v3
EXPERIAN_API_KEY=
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=

# CIBIL (TransUnion) API
CIBIL_API_URL=https://api.transunion.in/credit/v1
CIBIL_API_KEY=
CIBIL_CLIENT_ID=

# Perfios Income Verification
PERFIOS_API_URL=https://api.perfios.com/v2
PERFIOS_API_KEY=
PERFIOS_INSTITUTION_ID=

# Session TTL (seconds)
SESSION_TTL_SECONDS=3600

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
